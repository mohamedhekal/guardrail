{
    "name": "mohamedhekal/guardrail",
    "description": "Team-scoped roles, abilities, and audited impersonation for Laravel SaaS",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "permissions",
        "roles",
        "teams",
        "impersonation",
        "saas",
        "acl",
        "php",
        "laravel-package",
        "rbac",
        "authorization",
        "access-control"
    ],
    "authors": [
        {
            "name": "Mohamed Hekal"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/auth": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Hekal\\GuardRail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hekal\\GuardRail\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hekal\\GuardRail\\GuardRailServiceProvider"
            ],
            "aliases": {
                "GuardRail": "Hekal\\GuardRail\\Facades\\GuardRail"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "homepage": "https://github.com/mohamedhekal/guardrail",
    "support": {
        "issues": "https://github.com/mohamedhekal/guardrail/issues",
        "source": "https://github.com/mohamedhekal/guardrail"
    }
}
